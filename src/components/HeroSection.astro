---
import heroImage from '@/assets/hero-woman-right.jpg';
const heroImageUrl = typeof heroImage === 'string' ? heroImage : heroImage.src;
---

<!-- Agregamos pt-20 (o la altura de tu navbar) para evitar solapamiento -->
<section id="inicio" class="relative min-h-screen flex items-center overflow-hidden pt-20 lg:pt-24">
  
  <!-- Background Image - CON will-change para evitar glitches -->
  <div class="absolute inset-0 w-full h-full will-change-transform">
    <img
      src={heroImageUrl}
      alt="Mujer elegante en salón de belleza"
      class="w-full h-full object-cover"
      style="animation: heroZoom 1.2s cubic-bezier(0, 0, 0.2, 1) forwards; will-change: transform, opacity;"
      decoding="async"
    />
    <div class="absolute inset-0 bg-gradient-to-r from-olive-dark/90 via-olive-dark/60 to-transparent"></div>
  </div>

  <div class="container mx-auto px-4 lg:px-8 relative z-10 w-full">
    <div class="max-w-2xl">
      
      <!-- Label -->
      <div style="opacity: 0; animation: fadeUp 0.8s cubic-bezier(0, 0, 0.2, 1) 0.2s forwards; will-change: transform, opacity;">
        <span class="inline-block text-rose-dusty font-body text-sm tracking-[0.3em] uppercase mb-4">
          Vitacura & Las Condes
        </span>
      </div>

      <!-- H1 -->
      <h1 class="font-display text-4xl sm:text-5xl md:text-6xl lg:text-7xl text-cream-light leading-tight mb-6" 
          style="opacity: 0; animation: fadeUp 0.8s cubic-bezier(0, 0, 0.2, 1) 0.4s forwards; will-change: transform, opacity;">
        Realza tu
        <span class="block italic text-rose-dusty">Belleza Natural</span>
        con Elegancia
      </h1>

      <!-- Párrafo -->
      <p class="text-cream-light/80 font-body text-lg md:text-xl mb-8 leading-relaxed max-w-lg" 
         style="opacity: 0; animation: fadeUp 0.8s cubic-bezier(0, 0, 0.2, 1) 0.6s forwards; will-change: transform, opacity;">
        Descubre una experiencia de belleza exclusiva en el corazón de Santiago. 
        Tratamientos personalizados con los más altos estándares de calidad.
      </p>

      <!-- Botones HTML puro -->
      <div class="flex flex-col sm:flex-row gap-4" 
           style="opacity: 0; animation: fadeUp 0.8s cubic-bezier(0, 0, 0.2, 1) 0.8s forwards; will-change: transform, opacity;">
        <a href="#agendar" class="inline-flex items-center justify-center px-8 py-4 bg-rose-dusty text-cream-light font-body font-medium rounded-full hover:bg-rose-dusty/90 transition-colors">
          Agendar una Cita
        </a>
        <a href="#servicios" class="inline-flex items-center justify-center px-8 py-4 border border-cream-light/30 text-cream-light font-body font-medium rounded-full hover:bg-cream-light/10 transition-colors">
          Ver Servicios
        </a>
      </div>
    </div>
  </div>

  <!-- Scroll Indicator -->
  <div class="absolute bottom-8 left-1/2 transform -translate-x-1/2 z-10" 
       style="opacity: 0; animation: fadeIn 0.8s cubic-bezier(0, 0, 0.2, 1) 1.2s forwards;">
    <a href="#servicios" class="flex flex-col items-center gap-2 text-cream-light/70 hover:text-rose-dusty transition-colors">
      <span class="text-xs font-body tracking-widest uppercase">Explorar</span>
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" 
           style="animation: bounceElegant 2s cubic-bezier(0.4, 0, 0.2, 1) infinite; will-change: transform;">
        <path d="m6 9 6 6 6-6"/>
      </svg>
    </a>
  </div>

  <!-- Decorative Line -->
  <div class="absolute right-8 lg:right-16 top-1/4 bottom-1/4 w-px bg-gradient-to-b from-transparent via-rose-dusty/50 to-transparent origin-top hidden md:block" 
       style="transform: scaleY(0); animation: scaleY 1s cubic-bezier(0, 0, 0.2, 1) 1s forwards; will-change: transform;">
  </div>
</section>

<style>
  @keyframes heroZoom {
    from { opacity: 0; transform: scale(1.1); }
    to { opacity: 1; transform: scale(1); }
  }
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(30px); }
    to { opacity: 1; transform: translateY(0); }
  }
  @keyframes fadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
  }
  @keyframes scaleY {
    from { transform: scaleY(0); }
    to { transform: scaleY(1); }
  }
  @keyframes bounceElegant {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(10px); }
  }
</style>