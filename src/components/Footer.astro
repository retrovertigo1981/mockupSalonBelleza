---
// FRONTMATTER: No hay imports necesarios, es estático
const quickLinks = ['Inicio', 'Servicios', 'Nosotros', 'Galería', 'Contacto'];
---

<!-- TEMPLATE: HTML exacto con clases Tailwind -->
<footer id="contacto" class="bg-olive-dark border-t border-cream-light/10">
  <div class="container mx-auto px-4 lg:px-8 py-16">
    <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-12">
      
      <!-- Brand -->
      <div class="lg:col-span-2">
        <a href="#inicio" class="inline-block mb-6">
          <span class="font-display text-3xl font-bold text-cream-light">
            Élite
          </span>
          <span class="block text-xs text-rose-dusty tracking-[0.3em] uppercase font-body">
            Beauty & Spa
          </span>
        </a>
        <p class="text-cream-light/60 font-body leading-relaxed max-w-md mb-6">
          Tu destino de belleza exclusivo en Vitacura. Ofrecemos tratamientos 
          personalizados con los más altos estándares de calidad para realzar 
          tu belleza natural.
        </p>
        <div class="flex gap-4">
          <!-- Instagram -->
          <a
            href="https://instagram.com"
            target="_blank"
            rel="noopener noreferrer"
            class="w-10 h-10 rounded-full border border-cream-light/20 flex items-center justify-center text-cream-light/60 hover:text-rose-dusty hover:border-rose-dusty transition-all duration-300"
            aria-label="Instagram"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="20" x="2" y="2" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" x2="17.51" y1="6.5" y2="6.5"/></svg>
          </a>
          <!-- Facebook -->
          <a
            href="https://facebook.com"
            target="_blank"
            rel="noopener noreferrer"
            class="w-10 h-10 rounded-full border border-cream-light/20 flex items-center justify-center text-cream-light/60 hover:text-rose-dusty hover:border-rose-dusty transition-all duration-300"
            aria-label="Facebook"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
          </a>
          <!-- Mail -->
          <a
            href="mailto:info@elitebeauty.cl"
            class="w-10 h-10 rounded-full border border-cream-light/20 flex items-center justify-center text-cream-light/60 hover:text-rose-dusty hover:border-rose-dusty transition-all duration-300"
            aria-label="Email"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
          </a>
        </div>
      </div>

      <!-- Quick Links -->
      <div>
        <h4 class="font-display text-lg text-cream-light mb-6">
          Enlaces Rápidos
        </h4>
        <ul class="space-y-3">
          {quickLinks.map((link) => (
            <li>
              <a
                href={`#${link.toLowerCase()}`}
                class="text-cream-light/60 hover:text-rose-dusty transition-colors duration-300 font-body text-sm"
              >
                {link}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h4 class="font-display text-lg text-cream-light mb-6">
          Contacto
        </h4>
        <ul class="space-y-4">
          <li class="flex items-start gap-3">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-rose-dusty mt-1 flex-shrink-0"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            <span class="text-cream-light/60 font-body text-sm">
              +56 2 2345 6789
            </span>
          </li>
          <li class="flex items-start gap-3">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-rose-dusty mt-1 flex-shrink-0"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
            <span class="text-cream-light/60 font-body text-sm">
              info@elitebeauty.cl
            </span>
          </li>
        </ul>
      </div>
    </div>

    <!-- Bottom Bar -->
    <div class="mt-12 pt-8 border-t border-cream-light/10 flex flex-col md:flex-row justify-between items-center gap-4">
      <p class="text-cream-light/40 font-body text-sm">
        © 2025 Élite Beauty & Spa. Todos los derechos reservados.
      </p>
      <p class="text-cream-light/40 font-body text-sm">
        Diseñado con <span class="text-rose-dusty">♥</span> por HEXAGONO, Chile
      </p>
    </div>
  </div>
</footer>